{
  "version": 2,
  "builds": [
    {
      "src": "api/index.php",
      "use": "vercel-php@0.6.0"
    },
    {
      "src": "public/**/*.{js,css,png,jpg,jpeg,svg,ico}",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "^/build/(.*)",
      "dest": "public/build/$1"
    },
    {
      "src": "^/(.*)",
      "dest": "api/index.php"
    }
  ]
}
